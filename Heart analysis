import React, { useState, useEffect } from "react";
import { base44 } from "@/api/base44Client";
import { useParams, useNavigate } from "react-router-dom";
import { ArrowLeft, Heart, User, Activity, Stethoscope, AlertCircle, CheckCircle, Trash2 } from "lucide-react";
import RiskBadge from "@/components/analysis/RiskBadge";
import { Button } from "@/components/ui/button";
import moment from "moment";

const riskColors = {
  Low: "from-emerald-500 to-emerald-600",
  Moderate: "from-amber-500 to-amber-600",
  High: "from-orange-500 to-orange-600",
  Critical: "from-red-500 to-red-600",
};

export default function AnalysisDetail() {
  const { id } = useParams();
  const navigate = useNavigate();
  const [analysis, setAnalysis] = useState(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    base44.entities.HeartAnalysis.get(id)
      .then(setAnalysis)
      .finally(() => setLoading(false));
  }, [id]);

  const handleDelete = async () => {
    if (!confirm("Delete this analysis?")) return;
    await base44.entities.HeartAnalysis.delete(id);
    navigate("/history");
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center h-64">
        <div className="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin" />
      </div>
    );
  }

  if (!analysis) {
    return (
      <div className="text-center py-20">
        <p className="text-muted-foreground">Analysis not found</p>
        <Button variant="outline" onClick={() => navigate("/")} className="mt-4 rounded-xl">Go Home</Button>
      </div>
    );
  }

  const a = analysis;
  const gradient = riskColors[a.risk_level] || riskColors.Low;

  const InfoItem = ({ label, value }) => value ? (
    <div className="flex justify-between py-2.5 border-b border-border last:border-0">
      <span className="text-sm text-muted-foreground">{label}</span>
      <span className="text-sm font-medium text-foreground">{value}</span>
    </div>
  ) : null;

  return (
    <div className="max-w-3xl mx-auto space-y-6">
      <button onClick={() => navigate(-1)} className="flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
        <ArrowLeft className="w-4 h-4" /> Back
      </button>

      {/* Risk Score Hero */}
      <div className={`bg-gradient-to-br ${gradient} rounded-2xl p-6 sm:p-8 text-white`}>
        <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <p className="text-white/70 text-sm font-medium uppercase tracking-wider">Risk Assessment</p>
            <h1 className="text-2xl sm:text-3xl font-heading font-bold mt-1">{a.patient_name}</h1>
            <p className="text-white/70 text-sm mt-1">
              {moment(a.created_date).format("MMMM D, YYYY · h:mm A")}
            </p>
          </div>
          <div className="flex items-center gap-4">
            <div className="text-center">
              <p className="text-4xl sm:text-5xl font-bold">{a.risk_score ?? "—"}</p>
              <p className="text-white/70 text-xs mt-1">Risk Score</p>
            </div>
            <div className="bg-white/20 backdrop-blur-sm rounded-xl px-4 py-2 text-center">
              <p className="font-bold text-lg">{a.risk_level}</p>
              <p className="text-white/70 text-xs">Risk Level</p>
            </div>
          </div>
        </div>
      </div>

      <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {/* Patient Info */}
        <div className="bg-white rounded-2xl border border-border p-5">
          <div className="flex items-center gap-2 mb-4">
            <User className="w-4 h-4 text-primary" />
            <h2 className="font-heading font-semibold text-foreground text-sm">Patient Info</h2>
          </div>
          <InfoItem label="Age" value={a.age} />
          <InfoItem label="Sex" value={a.sex} />
          <InfoItem label="BMI" value={a.bmi} />
        </div>

        {/* Vitals */}
        <div className="bg-white rounded-2xl border border-border p-5">
          <div className="flex items-center gap-2 mb-4">
            <Activity className="w-4 h-4 text-primary" />
            <h2 className="font-heading font-semibold text-foreground text-sm">Vitals</h2>
          </div>
          <InfoItem label="Resting BP" value={a.resting_bp ? `${a.resting_bp} mm Hg` : null} />
          <InfoItem label="Cholesterol" value={a.cholesterol ? `${a.cholesterol} mg/dl` : null} />
          <InfoItem label="Max Heart Rate" value={a.max_heart_rate} />
          <InfoItem label="Fasting Blood Sugar" value={a.fasting_blood_sugar} />
          <InfoItem label="Resting ECG" value={a.resting_ecg} />
        </div>

        {/* Clinical */}
        <div className="bg-white rounded-2xl border border-border p-5">
          <div className="flex items-center gap-2 mb-4">
            <Stethoscope className="w-4 h-4 text-primary" />
            <h2 className="font-heading font-semibold text-foreground text-sm">Clinical</h2>
          </div>
          <InfoItem label="Chest Pain Type" value={a.chest_pain_type} />
          <InfoItem label="Exercise Angina" value={a.exercise_angina} />
          <InfoItem label="Smoking" value={a.smoking_status} />
          <InfoItem label="Diabetes" value={a.diabetes} />
          <InfoItem label="Family History" value={a.family_history} />
        </div>

        {/* Risk Factors */}
        {a.risk_factors && (
          <div className="bg-white rounded-2xl border border-border p-5">
            <div className="flex items-center gap-2 mb-4">
              <AlertCircle className="w-4 h-4 text-orange-500" />
              <h2 className="font-heading font-semibold text-foreground text-sm">Risk Factors</h2>
            </div>
            <div className="flex flex-wrap gap-2">
              {a.risk_factors.split(",").map((f) => f.trim()).filter(Boolean).map((f) => (
                <span key={f} className="bg-orange-50 text-orange-700 border border-orange-200 text-xs font-medium px-2.5 py-1 rounded-full">{f}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* AI Summary */}
      {a.ai_summary && (
        <div className="bg-white rounded-2xl border border-border p-6">
          <div className="flex items-center gap-2 mb-4">
            <Heart className="w-4 h-4 text-primary" />
            <h2 className="font-heading font-semibold text-foreground">AI Analysis Summary</h2>
          </div>
          <p className="text-sm text-foreground leading-relaxed whitespace-pre-line">{a.ai_summary}</p>
        </div>
      )}

      {/* Recommendations */}
      {a.ai_recommendations && (
        <div className="bg-white rounded-2xl border border-border p-6">
          <div className="flex items-center gap-2 mb-4">
            <CheckCircle className="w-4 h-4 text-emerald-500" />
            <h2 className="font-heading font-semibold text-foreground">Recommendations</h2>
          </div>
          <p className="text-sm text-foreground leading-relaxed whitespace-pre-line">{a.ai_recommendations}</p>
        </div>
      )}

      {/* Delete */}
      <div className="flex justify-end">
        <Button variant="ghost" onClick={handleDelete} className="text-destructive hover:text-destructive hover:bg-destructive/10 rounded-xl">
          <Trash2 className="w-4 h-4 mr-1.5" /> Delete Analysis
        </Button>
      </div>
    </div>
  );
}
